# 数据库配置
DB_HOST=localhost
DB_PORT=3306
DB_NAME=my_platform
DB_USERNAME=root
DB_PASSWORD=your_db_password

# Redis 配置
REDIS_HOST=192.168.75.133
REDIS_PORT=6379
REDIS_PASSWORD=123456
REDIS_DB=0

# JWT 密钥（必填，至少 32 字符）
# 生成方式：openssl rand -base64 64
JWT_SECRET=

# 文件上传路径（可选，默认 ./uploads/avatars 和 ./uploads/files）
AVATAR_UPLOAD_PATH=./uploads/avatars
FILE_UPLOAD_PATH=./uploads/files